
<service>
  
  <!-- ID of the service. It should be unique across the Windows system-->
  <id>AcerService</id>
  <!-- Display name of the service -->
  <name>Acer Service</name>
  <!-- Service description -->
  <description>Acer Service</description>
  
  <!-- Path to the executable, which should be started -->
  <executable>%BASE%\AcerService.exe</executable>
  
  <logpath>C:\ProgramData\OEM\AcerService</logpath>
  
  <log mode="none"/>

</service>
